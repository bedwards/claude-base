{
  "name": "claude-base",
  "version": "0.1.0",
  "description": "Foundation for Claude Code projects, adhering to Anthropic engineering blog standards",
  "type": "module",
  "bin": {
    "claude-base-init": "./bin/init.ts"
  },
  "scripts": {
    "init": "tsx bin/init.ts",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:frontend\"",
    "dev:api": "tsx watch src/api/index.ts",
    "dev:frontend": "vite",
    "build": "npm run build:api && npm run build:frontend",
    "build:api": "tsc -p tsconfig.api.json",
    "build:frontend": "vite build",
    "start": "node dist/api/index.js",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "screenshot": "tsx tools/screenshots/capture.ts",
    "screenshot:compare": "tsx tools/screenshots/compare.ts",
    "db:up": "docker-compose up -d postgres",
    "db:down": "docker-compose down",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "discord:send": "tsx tools/discord/send.ts",
    "discord:read": "tsx tools/discord/read.ts",
    "gh:issue": "tsx tools/github/create-issue.ts",
    "gh:rate-limit": "tsx tools/github/check-rate-limit.ts",
    "prepare": "husky || true"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitest/coverage-v8": "^2.1.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.11.0",
    "husky": "^9.1.6",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
